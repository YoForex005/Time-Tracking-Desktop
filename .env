# Desktop app environment variables

# API base URL — the backend server address (production)
# NOTE: Must include /api suffix — all endpoint calls append /auth/..., /time/..., etc.
VITE_API_BASE=http://127.0.0.1:3005/api
VITE_WEB_APP_URL=http://localhost:3000
VITE_FORCE_LOCAL_WEB_APP=true

# For Electron main process scripts (tracker, screenshot uploader)
API_BASE=http://127.0.0.1:3005/api
WEB_APP_URL=http://localhost:3000
FORCE_LOCAL_WEB_APP=true

# ── WFH Screen Monitor ────────────────────────────────────────────────────────
# How often (ms) to capture a thumbnail and compare pixel hash.
# Lower = more responsive detection, slightly more CPU. Range: 5000–60000
WFH_CAPTURE_INTERVAL_MS=15000

# Thumbnail size for screen comparison (pixels).
# Smaller = faster hash, less sensitive. 160×90 is a good balance.
WFH_THUMB_WIDTH=160
WFH_THUMB_HEIGHT=90
